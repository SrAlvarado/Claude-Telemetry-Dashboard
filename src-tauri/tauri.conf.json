{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Telemetry Dashboard",
  "version": "0.1.0",
  "identifier": "com.pedallingprosystem.claude-telemetry",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Claude Telemetry Dashboard",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700,
        "theme": "Dark",
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ]
  }
}
